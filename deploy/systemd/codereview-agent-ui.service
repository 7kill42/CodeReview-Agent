[Unit]
Description=CodeReview-Agent Streamlit UI service
After=network.target codereview-agent-api.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/project/CodeReview-Agent
EnvironmentFile=/root/project/CodeReview-Agent/.env.production
ExecStart=/root/project/CodeReview-Agent/.venv/bin/streamlit run ui/app.py --server.address 127.0.0.1 --server.port 8501
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
