# Copy this file to:
#   /root/project/CodeReview-Agent/.env.production
#
# Then replace secrets before starting systemd services.

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6
LLM_API_KEY=
LLM_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional per-component LLM overrides
STYLE_AGENT_LLM_PROVIDER=
STYLE_AGENT_LLM_MODEL=
STYLE_AGENT_LLM_BASE_URL=
STYLE_AGENT_LLM_API_KEY=

SECURITY_AGENT_LLM_PROVIDER=
SECURITY_AGENT_LLM_MODEL=
SECURITY_AGENT_LLM_BASE_URL=
SECURITY_AGENT_LLM_API_KEY=

LOGIC_AGENT_LLM_PROVIDER=
LOGIC_AGENT_LLM_MODEL=
LOGIC_AGENT_LLM_BASE_URL=
LOGIC_AGENT_LLM_API_KEY=

PERFORMANCE_AGENT_LLM_PROVIDER=
PERFORMANCE_AGENT_LLM_MODEL=
PERFORMANCE_AGENT_LLM_BASE_URL=
PERFORMANCE_AGENT_LLM_API_KEY=

AGGREGATOR_LLM_PROVIDER=
AGGREGATOR_LLM_MODEL=
AGGREGATOR_LLM_BASE_URL=
AGGREGATOR_LLM_API_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=replace-with-a-random-secret

# Database / cache
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/codereview
REDIS_URL=redis://127.0.0.1:6379/0

# Runtime
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT_SECONDS=30
ENABLE_DEDUP_CACHE=true
DEDUP_CACHE_TTL=86400

# GitHub write-back
ENABLE_PR_COMMENT=true
ENABLE_INLINE_COMMENT=true

# Notifications
ENABLE_NOTIFY=false
SLACK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
NOTIFY_ON_SEVERITIES=CRITICAL,HIGH

# Streamlit UI
API_BASE=https://api.lonelydoll.cn
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=replace-with-a-strong-password
SECRET_KEY=replace-with-a-long-random-secret
