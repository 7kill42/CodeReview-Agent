# Multi-LLM example for lonelydoll.cn
#
# Recommended split:
# - SecurityAgent  -> Anthropic
# - LogicAgent     -> Anthropic
# - Aggregator     -> Anthropic
# - StyleAgent     -> DeepSeek
# - PerformanceAgent -> DeepSeek
#
# You can replace DeepSeek with any OpenAI-compatible provider by changing:
# - *_LLM_PROVIDER
# - *_LLM_MODEL
# - *_LLM_BASE_URL
# - *_LLM_API_KEY

# Global fallback
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6
LLM_API_KEY=
LLM_BASE_URL=

# Shared provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# StyleAgent -> cheaper model
STYLE_AGENT_LLM_PROVIDER=deepseek
STYLE_AGENT_LLM_MODEL=deepseek-chat
STYLE_AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
STYLE_AGENT_LLM_API_KEY=

# SecurityAgent -> strongest review model
SECURITY_AGENT_LLM_PROVIDER=anthropic
SECURITY_AGENT_LLM_MODEL=claude-opus-4-6
SECURITY_AGENT_LLM_BASE_URL=
SECURITY_AGENT_LLM_API_KEY=

# LogicAgent -> strongest reasoning model
LOGIC_AGENT_LLM_PROVIDER=anthropic
LOGIC_AGENT_LLM_MODEL=claude-opus-4-6
LOGIC_AGENT_LLM_BASE_URL=
LOGIC_AGENT_LLM_API_KEY=

# PerformanceAgent -> cheaper model
PERFORMANCE_AGENT_LLM_PROVIDER=deepseek
PERFORMANCE_AGENT_LLM_MODEL=deepseek-chat
PERFORMANCE_AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
PERFORMANCE_AGENT_LLM_API_KEY=

# Aggregator -> high quality summary
AGGREGATOR_LLM_PROVIDER=anthropic
AGGREGATOR_LLM_MODEL=claude-opus-4-6
AGGREGATOR_LLM_BASE_URL=
AGGREGATOR_LLM_API_KEY=

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Database / cache inside docker compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/codereview
REDIS_URL=redis://redis:6379/0

# Runtime
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT_SECONDS=30
ENABLE_DEDUP_CACHE=true
DEDUP_CACHE_TTL=86400

# GitHub write-back
ENABLE_PR_COMMENT=true
ENABLE_INLINE_COMMENT=true

# Notifications
ENABLE_NOTIFY=false
SLACK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
NOTIFY_ON_SEVERITIES=CRITICAL,HIGH

# Streamlit UI
API_BASE=http://api.lonelydoll.cn
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
SECRET_KEY=
