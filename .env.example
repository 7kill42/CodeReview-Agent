# LLM Provider selection
# Supported: anthropic (default), openai, azure, deepseek, groq, openrouter, ollama, dashscope, qwenapi, qwencloud
LLM_PROVIDER=anthropic
# Model name for the selected provider
LLM_MODEL=claude-opus-4-6
# Optional explicit API key override for the selected provider
LLM_API_KEY=
# Base URL for OpenAI-compatible providers (leave blank for official OpenAI)
# DeepSeek:   LLM_BASE_URL=https://api.deepseek.com/v1
# Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1
# OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1
# Qwen API:   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1
LLM_BASE_URL=

# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional per-component LLM overrides. Leave blank to inherit the global values above.
# This lets you mix providers/models, for example:
#   SECURITY_AGENT_LLM_PROVIDER=anthropic
#   STYLE_AGENT_LLM_PROVIDER=openrouter
#   STYLE_AGENT_LLM_BASE_URL=https://openrouter.ai/api/v1
#   STYLE_AGENT_LLM_API_KEY=sk-or-...
STYLE_AGENT_LLM_PROVIDER=
STYLE_AGENT_LLM_MODEL=
STYLE_AGENT_LLM_BASE_URL=
STYLE_AGENT_LLM_API_KEY=

SECURITY_AGENT_LLM_PROVIDER=
SECURITY_AGENT_LLM_MODEL=
SECURITY_AGENT_LLM_BASE_URL=
SECURITY_AGENT_LLM_API_KEY=

LOGIC_AGENT_LLM_PROVIDER=
LOGIC_AGENT_LLM_MODEL=
LOGIC_AGENT_LLM_BASE_URL=
LOGIC_AGENT_LLM_API_KEY=

PERFORMANCE_AGENT_LLM_PROVIDER=
PERFORMANCE_AGENT_LLM_MODEL=
PERFORMANCE_AGENT_LLM_BASE_URL=
PERFORMANCE_AGENT_LLM_API_KEY=

AGGREGATOR_LLM_PROVIDER=
AGGREGATOR_LLM_MODEL=
AGGREGATOR_LLM_BASE_URL=
AGGREGATOR_LLM_API_KEY=

# GitHub
GITHUB_TOKEN=ghp_...

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codereview

# Redis
REDIS_URL=redis://localhost:6379/0

# Agent configuration
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT_SECONDS=30

# PR comment write-back (set to true to post results on GitHub)
ENABLE_PR_COMMENT=false
ENABLE_INLINE_COMMENT=false

# Dedup cache (skip agents if same PR commit SHA was already reviewed)
ENABLE_DEDUP_CACHE=true
DEDUP_CACHE_TTL=86400

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=

# Notifications
ENABLE_NOTIFY=false
SLACK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
NOTIFY_ON_SEVERITIES=CRITICAL,HIGH
