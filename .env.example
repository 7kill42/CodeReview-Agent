# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# GitHub
GITHUB_TOKEN=ghp_...

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codereview

# Redis
REDIS_URL=redis://localhost:6379/0

# Agent configuration
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT_SECONDS=30

# PR comment write-back (set to true to post results on GitHub)
ENABLE_PR_COMMENT=false
ENABLE_INLINE_COMMENT=false

# Dedup cache (skip agents if same PR commit SHA was already reviewed)
ENABLE_DEDUP_CACHE=true
DEDUP_CACHE_TTL=86400

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=

# Notifications
ENABLE_NOTIFY=false
SLACK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
NOTIFY_ON_SEVERITIES=CRITICAL,HIGH
